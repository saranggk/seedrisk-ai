# Get a key at https://console.anthropic.com/ — optional for local dev.
# Copy this file to .env and fill it in to enable the Claude analyst layer.
# Without it (or if the Claude call fails), POST /matches/{id}/analysis
# falls back to a deterministic mock report — the app works either way.
ANTHROPIC_API_KEY=

# Optional — overrides the model used for the analyst layer. Defaults to
# claude-sonnet-4-6 if unset; the analyst report is a grounded explanation
# task over structured data, not a task that needs Opus-level reasoning.
ANTHROPIC_MODEL=
