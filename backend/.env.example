# Get a key at https://console.anthropic.com/ — required to run the backend.
# Copy this file to .env and fill it in. The Claude analyst layer
# (POST /matches/{id}/analysis, POST /picks/analysis) has no mock fallback;
# the server refuses to start without this set.
ANTHROPIC_API_KEY=

# Optional — overrides the model used for the analyst layer. Defaults to
# claude-sonnet-4-6 if unset; the analyst report is a grounded explanation
# task over structured data, not a task that needs Opus-level reasoning.
ANTHROPIC_MODEL=

# Optional, comma-separated — extra origins allowed to call this API beyond
# the two local dev origins (e.g. your deployed frontend's URL, such as
# https://seedrisk.vercel.app). Not needed for local dev.
ALLOWED_ORIGINS=
